<% layout("/layouts/boilerplate") %>

    <body>
        <h3>Create new Listing!</h3>
        <form action="/listings" method="post">
            <input type="text" placeholder="Enter title" name="listing[title]">
            <br><br>
            <textarea name="listing[description]" placeholder="Enter description"></textarea><br><br>
            <input type="text" placeholder="Enter price" name="listing[price]"><br><br>
            <input type="text" placeholder="Enter country" name="listing[country]"><br><br>
            <input type="text" placeholder="Enter image url" name="listing[image]"><br><br>
            <input type="text" placeholder="Enter location" name="listing[location]"><br><br>
            <button>Create New</button>
        </form>
    </body>