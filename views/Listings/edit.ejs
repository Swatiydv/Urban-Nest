<% layout("/layouts/boilerplate") %>

    <body>
        <h3>Edit Listing!</h3>
        <form action="/listings/<%= listing._id %>?_method=PUT" method="post">
            <input type="text" value="<%= listing.title %>" name="listing[title]">
            <br><br>
            <textarea name="listing[description]"><%= listing.description %></textarea><br><br>
            <input type="text" value="<%= listing.price %>" name="listing[price]"><br><br>
            <input type="text" value="<%= listing.country %>" name="listing[country]"><br><br>
            <input type="text" value="<%= listing.image %>" name="listing[image]"><br><br>
            <input type="text" value="<%= listing.location %>" name="listing[location]"><br><br>
            <button>Edit</button>
        </form>
    </body>